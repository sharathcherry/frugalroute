# ── FrugalRoute env template ─────────────────────────────────────────────
# Copy to .env for local dev, OR set these as variables in the Railway
# backend service. Never commit real keys (.env is gitignored).

MOCK=0

# ── Local (FREE) model — hosted on AMD MI300X via vLLM (OpenAI-compatible) ──
# After you start vLLM on the AMD Developer Cloud, paste its public URL here.
LOCAL_BASE_URL=https://<your-mi300x-host>/v1
LOCAL_API_KEY=<the --api-key you passed to vLLM>
LOCAL_MODEL=Qwen/Qwen2.5-32B-Instruct

# ── Remote (PAID) escalation — Fireworks ──
REMOTE_PROVIDER=fireworks
REMOTE_BASE_URL=https://api.fireworks.ai/inference/v1
REMOTE_API_KEY=fw_xxxxxxxx
REMOTE_MODEL=accounts/fireworks/models/gpt-oss-120b

# ── Routing knobs ──
GATE_MODE=calibrated
JUDGE_MODE=selfrate
CONFIDENCE_THRESHOLD=0.55
CALIB_PATH=calib.json
COMPRESS=1
CACHE_ENABLED=0
FAST_GATE=1

# ── CORS — set to your frontend Railway URL (comma-separated), or * ──
ALLOW_ORIGINS=*
